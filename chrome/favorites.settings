  "icon-url-mapping": "# Syntax: A > B\n# For each bookmark URL starting with A, an icon is loaded from B.\n# Lines starting with # are ignored and can be used for comments.\n\nhttps://discord.com/ > https://nektony.com/wp-content/uploads/2019/07/discord-icon.png\nhttps://slack.com/ > https://www.itprotoday.com/sites/itprotoday.com/files/appIcon_desktop.png\nhttps://www.uhc.com/ > http://www.ipharmd.net/images/white_caduceus_red_box.png\nhttps://microservices.io/ > https://vectorified.com/images/micro-service-icon-20.png\nhttps://play.google.com/books > http://icons.iconarchive.com/icons/dtafalonso/android-lollipop/512/Play-Books-icon.png\nhttps://neuvoo.com/tax-calculator/ > https://assets.webinfcdn.net/favicons/b/blog.neuvoo.com.ico\nhttp://libgen.rs/ > https://styles.redditmedia.com/t5_2n5nva/styles/communityIcon_wi4sdjng8cx41.PNG?width=256&s=d08139af64256381f196e65228f4a6145639cef8\nhttps://business.google.com/ > https://ardentgrowth.com/wp-content/uploads/2019/02/google-my-business-icon.png\nhttps://www.youtube.com/ > https://freepngimg.com/thumb/youtube/77825-play-icons-button-youtube-computer-icon-thumb.png\nhttp://www.phillylinux.org/ > http://2.bp.blogspot.com/_UqUwVPikChs/SmrOJVe4cxI/AAAAAAAAJyM/FutQsRpoPeU/s320/xanderrun-philly-tux-8733.png\nhttps://www.meetup.com/home/ > https://www.underconsideration.com/brandnew/archives/meetup_monogram.png\nhttps://west-developu.percipio.com/login.html?state=%2F#/ > https://i0.wp.com/cdng.c3dt.com/icon/3478775-com.skillsoft.Percipio.png\n",
